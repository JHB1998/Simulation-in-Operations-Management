						<Parameter>
							<Name><![CDATA[onEnter]]></Name>
							<Value Class="CodeValue">
								<Code><![CDATA[int fullBottles = agent.tabletsInBatch / agent.bottleSize;
int packagedTablets = fullBottles * agent.bottleSize;
int scrap = agent.tabletsInBatch - packagedTablets;

agent.tabletsInBatch = packagedTablets;
scrapCount += scrap;]]></Code>
							</Value>
						</Parameter>
						<Parameter>
							<Name><![CDATA[onExitTimeout]]></Name>
						</Parameter>
						<Parameter>
							<Name><![CDATA[onExitPreempted]]></Name>
