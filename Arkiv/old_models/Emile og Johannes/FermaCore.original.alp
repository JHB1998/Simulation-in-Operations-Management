						<Parameter>
							<Name><![CDATA[onAtExit]]></Name>
						</Parameter>
						<Parameter>
							<Name><![CDATA[onExit]]></Name>
							<Value Class="CodeValue">
								<Code><![CDATA[double leadTime = time() - agent.entryTime;

batchCount++;
totalTablets += agent.tabletsInBatch;

avgLeadTime = avgLeadTime + (leadTime - avgLeadTime) / batchCount;

traceln("FINISHED batch " + agent.batchID +
        " | product = " + agent.productType +
        " | tablets packaged = " + agent.tabletsInBatch +
        " | lead time = " + leadTime);]]></Code>
							</Value>
						</Parameter>
