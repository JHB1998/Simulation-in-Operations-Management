						<Parameter>
							<Name><![CDATA[onExit]]></Name>
							<Value Class="CodeValue">
								<Code><![CDATA[batchCreated++;

agent.entryTime = time();
agent.batchID = batchCreated;

agent.productType = selectFrom(plan)
    .where(plan.order_db.eq(agent.batchID))
    .firstResult(plan.product);

int activeKg = selectFrom(plan)
    .where(plan.order_db.eq(agent.batchID))
    .firstResult(plan.kg);

agent.coatingRequired = !agent.productType.equals("CoreTab");

agent.tabletsInBatch = activeKg * 1000 * 1000 / 500;

if (agent.productType.equals("MaxTab")) {
    agent.bottleSize = 300;
} else {
    agent.bottleSize = 180;
}

traceln("Batch " + agent.batchID +
        " | product = " + agent.productType +
        " | kg = " + activeKg +
        " | tablets = " + agent.tabletsInBatch +
        " | coatingRequired = " + agent.coatingRequired);]]></Code>
							</Value>
