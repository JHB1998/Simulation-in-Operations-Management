						<Parameter>
							<Name><![CDATA[onEnter]]></Name>
							<Value Class="CodeValue">
								<Code><![CDATA[int beforeYield = agent.tabletsInBatch;

double packagingYield = triangular(0.990, 0.995, 0.998);

agent.tabletsInBatch = (int)(agent.tabletsInBatch * packagingYield);

scrapCount += beforeYield - agent.tabletsInBatch;

int fullBottles = agent.tabletsInBatch / agent.bottleSize;
int packagedTablets = fullBottles * agent.bottleSize;
int bottleScrap = agent.tabletsInBatch - packagedTablets;

agent.tabletsInBatch = packagedTablets;
scrapCount += bottleScrap;

traceln(
    "PACKAGING batch " + agent.batchID +
    " | after packaging yield + bottle rounding = " +
    agent.tabletsInBatch
);]]></Code>
							</Value>
						</Parameter>
