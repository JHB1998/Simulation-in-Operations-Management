					<Name><![CDATA[batchSink]]></Name>
					<X>3220</X><Y>440</Y>
					<Label><X>-15</X><Y>-25</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
