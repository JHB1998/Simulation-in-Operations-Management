					<Parameters>
						<Parameter>
							<Name><![CDATA[onEnter]]></Name>
							<Value Class="CodeValue">
								<Code><![CDATA[batchCount++;

totalTablets += agent.tabletsInBatch;

double leadTime = time() - agent.entryTime;

avgLeadTime =
    ((avgLeadTime * (batchCount - 1)) + leadTime)
    / batchCount;

scrapRate = 100.0 * scrapCount / (totalTablets + scrapCount);

completedBatchRate = 100.0 * batchCount / batchCreated;

dryerUtilisation = 100.0 * dryer.utilization();

blenderUtilisation = 100.0 * blenders.utilization();

compressorUtilisation = 100.0 * compressors.utilization();

coaterUtilisation = 100.0 * coater.utilization();

packagingUtilisation = 100.0 * packagingLines.utilization();

cleaningTeamUtilisation = 100.0 * cleaningTeam.utilization();

avgPremixQueue = premixQueue.statsSize.mean();

avgCoatingQueue = coatingQueue.statsSize.mean();

avgPackagingQueue = packagingQueue.statsSize.mean();]]></Code>
							</Value>
						</Parameter>
						<Parameter>
							<Name><![CDATA[destroyEntity]]></Name>
						</Parameter>
					</Parameters>
