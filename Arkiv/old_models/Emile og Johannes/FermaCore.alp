// Packaging quality yield
double packagingYield = triangular(0.990, 0.995, 0.998);
agent.tabletsInBatch = (int) (agent.tabletsInBatch * packagingYield);

scrapCount += before - agent.tabletsInBatch;

// Tablets must fill whole bottles
int tabletsPerBottle = agent.bottleSize;
int finishedTablets =
    (agent.tabletsInBatch / tabletsPerBottle) * tabletsPerBottle;

scrapCount += agent.tabletsInBatch - finishedTablets;

agent.tabletsInBatch = finishedTablets;]]></Code>
							</Value>
						</Parameter>
						<Parameter>
							<Name><![CDATA[onExit]]></Name>
						</Parameter>
						<Parameter>
							<Name><![CDATA[onWrapUpTerminated]]></Name>
						</Parameter>
					</Parameters>
