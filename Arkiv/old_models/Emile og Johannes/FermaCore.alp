							<Name><![CDATA[onExit]]></Name>
							<Value Class="CodeValue">
								<Code><![CDATA[Blender b = (Blender) agent.resourceUnitOfPool(blenders);


if (b.currentBatch == agent) {
    b.currentBatch = null;
}]]></Code>
							</Value>
