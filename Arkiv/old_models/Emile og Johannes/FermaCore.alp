							<Name><![CDATA[delayTime]]></Name>
							<Value Class="CodeUnitValue">
								<Code><![CDATA[((Blender) agent.resourceUnitOfPool(blenders)).isNew
? triangular(3.5, 4.0, 4.5)
: triangular(4.5, 5.5, 6.5)]]></Code>
								<Unit Class="TimeUnits"><![CDATA[HOUR]]></Unit>
							</Value>
