]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1783000000189</Id>
					<Name><![CDATA[dryingTime]]></Name>
					<X>-300</X><Y>140</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[// Fitted from 300 DryingConditioning observations in FermaCore_input_data.xlsx.
// min = 2.703493 h, max = 5.541093 h, mean = 3.997781 h.
// Triangular mode inferred from mean: mode = 3*mean - min - max = 3.748756 h.
return triangular(2.703493, 5.541093, 3.748756);
]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1783000000190</Id>
					<Name><![CDATA[premixDurationNew]]></Name>
					<X>-180</X><Y>500</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[a]]></Name>
						<Type><![CDATA[BatchAgent]]></Type>
					</Parameter>
					<Body><![CDATA[double d = triangular(3.5, 4.5, 4.0);
a.premixUnit = "New";
a.premixProcessTime = d;
return d;
]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1783000000191</Id>
					<Name><![CDATA[premixDurationOld]]></Name>
					<X>-180</X><Y>560</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[a]]></Name>
						<Type><![CDATA[BatchAgent]]></Type>
					</Parameter>
					<Body><![CDATA[double d = triangular(4.5, 6.5, 5.5);
a.premixUnit = "Old";
a.premixProcessTime = d;
return d;
]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[int]]></ReturnType>
					<Id>1783000000192</Id>
					<Name><![CDATA[choosePackagingLine]]></Name>
					<X>-180</X><Y>620</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[product]]></Name>
						<Type><![CDATA[String]]></Type>
					</Parameter>
					<Body><![CDATA[int n = Math.min(numPackagingLines, lastProductOnPackLine.length);
if (n <= 0) return 0;

// Prefer an idle line that already handled this product, to avoid a changeover.
for (int i = 0; i < n; i++) {
    if (!packLineBusy[i] && product.equals(lastProductOnPackLine[i])) {
        return i;
    }
}

// Otherwise use the first idle line.
for (int i = 0; i < n; i++) {
    if (!packLineBusy[i]) {
        return i;
    }
}

// Defensive fallback. This should rarely be used because the Seize block exits only after a packaging resource is available.
return 0;
]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1783000000193</Id>
					<Name><![CDATA[assignPackagingLine]]></Name>
					<X>-180</X><Y>680</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[a]]></Name>
						<Type><![CDATA[BatchAgent]]></Type>
					</Parameter>
					<Body><![CDATA[int i = choosePackagingLine(a.product);
a.packLineIndex = i;
a.productChanged = lastProductOnPackLine[i].length() > 0 && !a.product.equals(lastProductOnPackLine[i]);
if (a.productChanged) numChangeovers++;
packLineBusy[i] = true;
]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1783000000194</Id>
					<Name><![CDATA[releasePackagingLine]]></Name>
					<X>-180</X><Y>740</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[a]]></Name>
						<Type><![CDATA[BatchAgent]]></Type>
					</Parameter>
					<Body><![CDATA[int i = a.packLineIndex;
if (i >= 0 && i < lastProductOnPackLine.length) {
    lastProductOnPackLine[i] = a.product;
    packLineBusy[i] = false;
}
lastProductOnLine = a.product; // kept as a fallback/readout from the older single-line logic
a.packLineIndex = -1;
]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>9001000000002</Id>
					<Name><![CDATA[onTimeRate]]></Name>
					<X>-300</X><Y>440</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[int total = batchesOnTime + batchesLate;
return total > 0 ? ((double)batchesOnTime) / total : 0;
]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[String]]></ReturnType>
					<Id>9001000000003</Id>
					<Name><![CDATA[weeklyShipmentReport]]></Name>
					<X>-300</X><Y>500</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[StringBuilder sb = new StringBuilder("=== WEEKLY SHIPMENT REPORT ===\n");
for (int w = 0; w < weeklyBottlesShipped.length; w++) {
    if (weeklyBottlesShipped[w] > 0) {
        sb.append("  Week ").append(w + 1).append(": ").append((long)weeklyBottlesShipped[w]).append(" bottles\n");
    }
}
sb.append("  ON-TIME RATE: ").append(String.format("%.1f%%", onTimeRate() * 100))
  .append("  (").append(batchesOnTime).append(" on-time, ").append(batchesLate).append(" late)");
return sb.toString();
]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[String]]></ReturnType>
					<Id>9001000000007</Id>
					<Name><![CDATA[bottleneckReport]]></Name>
					<X>-300</X><Y>560</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[StringBuilder sb = new StringBuilder("=== BOTTLENECK REPORT ===\n");
sb.append(String.format("  %-26s  %6s  %8s\n", "Resource", "Units", "Utiliz."));
sb.append(String.format("  %-26s  %6s  %8s\n", "--------", "-----", "-------"));
sb.append(String.format("  %-26s  %6d  %7.1f%%\n", "blenderNew",     1,                   blenderNew.utilization()*100));
sb.append(String.format("  %-26s  %6d  %7.1f%%\n", "blenderOld",     1,                   blenderOld.utilization()*100));
sb.append(String.format("  %-26s  %6d  %7.1f%%\n", "granulator",     1,                   granulator.utilization()*100));
sb.append(String.format("  %-26s  %6d  %7.1f%%\n", "dryer",          numDryers,           dryer.utilization()*100));
sb.append(String.format("  %-26s  %6d  %7.1f%%\n", "press",          3,                   press.utilization()*100));
sb.append(String.format("  %-26s  %6d  %7.1f%%\n", "coater",         1,                   coater.utilization()*100));
sb.append(String.format("  %-26s  %6d  %7.1f%%\n", "packagingLine",  numPackagingLines,   packagingLine.utilization()*100));
sb.append(String.format("  %-26s  %6d  %7.1f%%  (dry+coat+pkg)\n",  "cleaningTeam", cleaningTeamCapacity, cleaningTeam.utilization()*100));
sb.append("\n  --- PERFORMANCE SUMMARY ---\n");
sb.append(String.format("  shipped=%d  scrapped=%d  scrapRate=%.1f%%\n", batchesShipped, batchesScrapped, scrapRate()*100));
sb.append(String.format("  meanFlowTime=%.2fh  maxFlowTime=%.2fh\n", meanFlowTime(), maxFlowTime));
sb.append(String.format("  totalBottles=%d  onTimeRate=%.1f%%  changeovers=%d", (long)totalBottlesShipped, onTimeRate()*100, numChangeovers));
return sb.toString();
]]></Body>
				</Function>
