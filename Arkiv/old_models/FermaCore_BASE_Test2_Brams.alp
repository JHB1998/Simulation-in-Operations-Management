				<EmbeddedObject>
					<Id>1783000000144</Id>
					<Name><![CDATA[sinkShipped]]></Name>
					<X>1210</X><Y>650</Y>
					<Label><X>-25</X><Y>-20</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<ActiveObjectClass>
						<PackageName><![CDATA[com.anylogic.libraries.processmodeling]]></PackageName>
						<ClassName><![CDATA[Sink]]></ClassName>
					</ActiveObjectClass>
					<GenericParameterSubstitute>
						<GenericParameterSubstituteReference>
							<PackageName><![CDATA[com.anylogic.libraries.processmodeling]]></PackageName>
							<ClassName><![CDATA[Sink]]></ClassName>
							<ItemName><![CDATA[1412336242929]]></ItemName>
						</GenericParameterSubstituteReference>
					</GenericParameterSubstitute>
					<Parameters>
						<Parameter>
							<Name><![CDATA[onEnter]]></Name>
							<Value Class="CodeValue">
								<Code><![CDATA[int bs = bottleSize(agent.product);
agent.bottlesShipped = Math.floor(agent.tablets / bs);
agent.tablets = agent.bottlesShipped * bs;
batchesShipped++;
double ft = time() - agent.arrivalTime;
totalFlowTime += ft;
maxFlowTime = Math.max(maxFlowTime, ft);
totalTabletsShipped += agent.tablets;
totalBottlesShipped += agent.bottlesShipped;
int weekNum = (int)(time() / 168.0);
if (weekNum < weeklyBottlesShipped.length) {
    weeklyBottlesShipped[weekNum] += agent.bottlesShipped;
}
traceln("SHIPPED  | t=" + String.format("%.2f", time()) + " | product=" + agent.product
    + " | tablets=" + (long)agent.tablets + " | bottles=" + (long)agent.bottlesShipped
    + " | flowTime=" + String.format("%.2f h", ft) + " | week=" + (weekNum + 1));
if (batchesShipped + batchesScrapped >= 50) {
    traceln(weeklyShipmentReport());
    traceln(bottleneckReport());
}
]]></Code>
							</Value>
						</Parameter>
						<Parameter>
							<Name><![CDATA[destroyEntity]]></Name>
							<Value Class="CodeValue">
								<Code><![CDATA[true]]></Code>
							</Value>
						</Parameter>
					</Parameters>
