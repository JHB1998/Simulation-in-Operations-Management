						<Parameter>
							<Name><![CDATA[onEnter]]></Name>
							<Value Class="CodeValue">
								<Code><![CDATA[agent.premixUnit = "New";
agent.premixStartTime = time();
double deviation = time() - agent.arrivalTime;
if (deviation > 24.0) {
    batchesLate++;
    traceln("LATE     | t=" + String.format("%.2f", time()) + " | product=" + agent.product + " | blender=New | deviation=" + String.format("%.1f h", deviation));
} else {
    batchesOnTime++;
}
]]></Code>
							</Value>
						</Parameter>
						<Parameter>
							<Name><![CDATA[onAtExit]]></Name>
						</Parameter>
						<Parameter>
							<Name><![CDATA[onExit]]></Name>
							<Value Class="CodeValue">
								<Code><![CDATA[agent.premixYield = triangular(0.985, 0.990, 0.995);
agent.tablets = 300000 * agent.premixYield;]]></Code>
							</Value>
						</Parameter>
						<Parameter>
							<Name><![CDATA[onRemove]]></Name>
						</Parameter>
