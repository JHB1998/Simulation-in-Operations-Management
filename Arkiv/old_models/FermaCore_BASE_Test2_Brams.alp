		<ActiveObjectClass>
			<Id>1782117159878</Id>
			<Name><![CDATA[Main]]></Name>
			<StartupCode><![CDATA[// === VERIFICATION: DATA IMPORT CHECK ===
traceln("=== DATA CHECK ===");
traceln("productPlan.length = " + productPlan.length + "  (expect 50)");
traceln("arrivalTimes.length = " + arrivalTimes.length + "  (expect 50)");
int _core=0, _plus=0, _max=0;
for (String p : productPlan) {
    if (p.equals("CoreTab")) _core++;
    else if (p.equals("PlusTab")) _plus++;
    else if (p.equals("MaxTab")) _max++;
    else traceln("UNKNOWN PRODUCT: " + p);
}
traceln("CoreTab=" + _core + "  PlusTab=" + _plus + "  MaxTab=" + _max + "  (expect 17 / 18 / 15)");
traceln("First: " + productPlan[0] + "  Last: " + productPlan[productPlan.length-1]);
traceln("=== END DATA CHECK ===");

// Optional OFAT scenario: resequence all 50 planned batches by product.
// The arrival times stay unchanged; only product order changes.
if (groupByProduct) {
    java.util.Arrays.sort(productPlan);
}
]]></StartupCode>
