					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[product]]></Name>
						<Type><![CDATA[String]]></Type>
					</Parameter>
					<Body><![CDATA[return product.equals("MaxTab") ? 300 : 180;
]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[boolean]]></ReturnType>
					<Id>1783000000050</Id>
					<Name><![CDATA[isPackagingChangeover]]></Name>
					<X>-180</X><Y>260</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[a]]></Name>
						<Type><![CDATA[BatchAgent]]></Type>
					</Parameter>
					<Body><![CDATA[int i = a.packLineIndex;
if (i >= 0 && i < lastProductOnPackLine.length) {
    return lastProductOnPackLine[i].length() > 0 && !a.product.equals(lastProductOnPackLine[i]);
}
return lastProductOnLine.length() > 0 && !a.product.equals(lastProductOnLine);
]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1783000000051</Id>
					<Name><![CDATA[packagingSetupTime]]></Name>
					<X>-180</X><Y>320</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[a]]></Name>
						<Type><![CDATA[BatchAgent]]></Type>
					</Parameter>
					<Body><![CDATA[return 0.5 + (isPackagingChangeover(a) ? 0.5 : 0.0);
]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1783000000052</Id>
					<Name><![CDATA[meanFlowTime]]></Name>
					<X>-180</X><Y>380</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[return batchesShipped > 0 ? totalFlowTime / batchesShipped : 0;
]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1783000000053</Id>
					<Name><![CDATA[scrapRate]]></Name>
					<X>-180</X><Y>440</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[int total = batchesShipped + batchesScrapped;
return total > 0 ? ((double)batchesScrapped) / total : 0;
]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[boolean]]></ReturnType>
					<Id>1783000000188</Id>
