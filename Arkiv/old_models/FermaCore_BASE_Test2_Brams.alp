			<Functions>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1783000000047</Id>
					<Name><![CDATA[arrivalDelay]]></Name>
					<X>-180</X><Y>80</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[// Source uses interarrival times; this converts the absolute plan to gaps.
int i = Math.max(0, sourceIndex - 1);
if (i < arrivalTimes.length - 1) {
    return Math.max(0.0, (arrivalTimes[i + 1] - arrivalTimes[i]) / demandMultiplier);
}
return 1.0e9; // no more arrivals after maxArrivals
]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1783000000048</Id>
					<Name><![CDATA[premixFailureRate]]></Name>
					<X>-180</X><Y>140</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[a]]></Name>
						<Type><![CDATA[BatchAgent]]></Type>
					</Parameter>
					<Body><![CDATA[// Manual override: set premixFailureProbability to a value in [0,1] to force a fixed batch-scrap probability.
if (premixFailureProbability >= 0) {
    return Math.max(0.0, Math.min(1.0, premixFailureProbability));
}

// Old/new-specific approximation from the workbook failure frequencies.
// AnyLogic Weibull is weibull(alpha, beta), alpha=shape and beta=scale.
// Old: weibull(1.5, 2.5) days -> mean ≈ 54.165 h.
// New: weibull(0.5, 3.5) days -> mean = 168.000 h.
double duration = a.premixProcessTime > 0 ? a.premixProcessTime : (a.premixUnit.equals("Old") ? 5.5 : 4.0);
double mtbfHours = a.premixUnit.equals("Old") ? 54.164718 : 168.0;
mtbfHours *= mtbfMultiplier;

// Equivalent exponential hazard approximation over the batch's actual sampled premix duration.
double p = 1.0 - Math.exp(-duration / mtbfHours);
return Math.max(0.0, Math.min(0.95, p));
]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[int]]></ReturnType>
					<Id>1783000000049</Id>
					<Name><![CDATA[bottleSize]]></Name>
					<X>-180</X><Y>200</Y>
					<Label><X>10</X><Y>0</Y></Label>
