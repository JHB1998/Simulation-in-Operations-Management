						<Type><![CDATA[int]]></Type>
					</Parameter>
					<Body><![CDATA[tttG += modelEnd - timeStart;
attG = tttG / cG;

if (gate == 1) {
    tttG1 += modelEnd - timeStart;
    attG1 = tttG1 / cG1;
} else if (gate == 2) {
    tttG2 += modelEnd - timeStart;
    attG2 = tttG2 / cG2;
} else if (gate == 3) {
    tttG3 += modelEnd - timeStart;
    attG3 = tttG3 / cG3;
} else if (gate == 4) {
    tttG4 += modelEnd - timeStart;
    attG4 = tttG4 / cG4;
} else if (gate == 5) {
    tttG5 += modelEnd - timeStart;
    attG5 = tttG5 / cG5;
};]]></Body>
				</Function>
			</Functions>
