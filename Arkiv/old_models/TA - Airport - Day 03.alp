						<Parameter>
							<Name><![CDATA[onExit]]></Name>
							<Value Class="CodeValue">
								<Code><![CDATA[// Adding +1 to count
cG4++;
cG++;
// Adding finish time to local variable (agent).  
agent.OUT = time();
// Calculating and adding total operation time to global variable. 
totG4 += (agent.OUT - agent.INO);
totG += (agent.OUT - agent.INO);
// Calculating util for resource
updateUtil();
// Calculating avg. queue time.
aqtG4 = tqtG4 / cG4;
aqtG = tqtG / cG;
// Print text to console.
System.out.println("Total operation time for flight " + agent.ID + " took " + String.format("%.2f", agent.OUT - agent.INO) +" minutes.")]]></Code>
							</Value>
