			<CommandLineArguments><![CDATA[]]></CommandLineArguments>
			<InitialSetupCode><![CDATA[excelFile.setCellValue("Replication Number",1, 1, 1); 
excelFile.setCellValue("AvgTurnaroundTime",1, 1, 2); 
excelFile.setCellValue("AvgQueueTime",1, 1, 3); 
excelFile.setCellValue("Utilization",1, 1, 4); ]]></InitialSetupCode>
			<MaximumMemory>512</MaximumMemory>
			<RandomNumberGenerationType>randomSeed</RandomNumberGenerationType>
			<CustomGeneratorCode>new Random()</CustomGeneratorCode>
			<AfterSimulationRunCode><![CDATA[excelFile.setCellValue(row-1, 1, row, column); 
column++;
excelFile.setCellValue(root.attG,1, row, column);
column++;
excelFile.setCellValue(root.aqtG,1, row, column);
column++;
excelFile.setCellValue(root.uG,1, row, column);
column++;
column=1;
row++;]]></AfterSimulationRunCode>
			<SeedValue>1</SeedValue>
