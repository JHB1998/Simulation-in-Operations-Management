			<Functions>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1783000000047</Id>
					<Name><![CDATA[arrivalDelay]]></Name>
					<X>-170</X><Y>60</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[// Source uses interarrival times; this converts the absolute plan to gaps.
double dm = Math.max(1.0e-9, demandMultiplier);
int i = Math.max(0, sourceIndex - 1);
if (i < arrivalTimes.length - 1) {
    return Math.max(0.0, (arrivalTimes[i + 1] - arrivalTimes[i]) / dm);
}
return 1.0e9; // no more arrivals after targetBatchCount]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1783000000048</Id>
					<Name><![CDATA[premixFailureRate]]></Name>
					<X>-170</X><Y>80</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[a]]></Name>
						<Type><![CDATA[BatchAgent]]></Type>
					</Parameter>
					<Body><![CDATA[// Manual override: set premixFailureProbability to a value in [0,1] to force a fixed batch-scrap probability.
if (premixFailureProbability >= 0) {
    return Math.max(0.0, Math.min(1.0, premixFailureProbability));
}

// Old/new-specific approximation from the workbook failure frequencies.
// AnyLogic Weibull is weibull(alpha, beta), alpha=shape and beta=scale.
// Old: weibull(1.5, 2.5) days -> mean ≈ 54.165 h.
// New: weibull(0.5, 3.5) days -> mean = 168.000 h.
double duration = a.premixProcessTime > 0 ? a.premixProcessTime : (a.premixUnit.equals("Old") ? 5.5 : 4.0);
double mtbfHours = a.premixUnit.equals("Old") ? 54.164718 : 168.0;
mtbfHours *= mtbfMultiplier;

// Equivalent exponential hazard approximation over the batch's actual sampled premix duration.
double p = 1.0 - Math.exp(-duration / mtbfHours);
return Math.max(0.0, Math.min(0.95, p));
]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[int]]></ReturnType>
					<Id>1783000000049</Id>
					<Name><![CDATA[bottleSize]]></Name>
					<X>-170</X><Y>100</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[product]]></Name>
						<Type><![CDATA[String]]></Type>
					</Parameter>
					<Body><![CDATA[return product.equals("MaxTab") ? 300 : 180;
]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[boolean]]></ReturnType>
					<Id>1783000000050</Id>
					<Name><![CDATA[isPackagingChangeover]]></Name>
					<X>-170</X><Y>120</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[a]]></Name>
						<Type><![CDATA[BatchAgent]]></Type>
					</Parameter>
					<Body><![CDATA[int i = a.packLineIndex;
if (i >= 0 && i < lastProductOnPackLine.length) {
    return lastProductOnPackLine[i].length() > 0 && !a.product.equals(lastProductOnPackLine[i]);
}
return lastProductOnLine.length() > 0 && !a.product.equals(lastProductOnLine);
]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1783000000051</Id>
					<Name><![CDATA[packagingSetupTime]]></Name>
					<X>-170</X><Y>140</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[a]]></Name>
						<Type><![CDATA[BatchAgent]]></Type>
					</Parameter>
					<Body><![CDATA[if (a.setupTimeUsed > 0) return a.setupTimeUsed;
return 0.5 + (isPackagingChangeover(a) ? 0.5 : 0.0);]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1783000000052</Id>
					<Name><![CDATA[meanFlowTime]]></Name>
					<X>-170</X><Y>160</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[return batchesShipped > 0 ? totalFlowTime / batchesShipped : 0;
]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1783000000053</Id>
					<Name><![CDATA[scrapRate]]></Name>
					<X>-170</X><Y>180</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[int total = batchesShipped + batchesScrapped;
return total > 0 ? ((double)batchesScrapped) / total : 0;
]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1783000000901</Id>
					<Name><![CDATA[printBaselineResults]]></Name>
					<X>-170</X><Y>200</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[traceln("");
traceln("=== BASELINE RESULTS ===");
traceln("Sim time at completion (h): " + String.format("%.2f", time()));
traceln("Batches shipped:  " + batchesShipped);
traceln("Batches scrapped: " + batchesScrapped);
traceln("Total completed:  " + (batchesShipped + batchesScrapped) + "  (expect " + targetBatchCount + ")");
traceln("Scrap rate:       " + String.format("%.3f", scrapRate()));
traceln("Mean flow time, shipped only (h): " + String.format("%.2f", meanFlowTime()));
traceln("Max flow time, shipped only (h):  " + String.format("%.2f", maxFlowTime));
traceln("Max WIP observed: " + maxWIP);
traceln("Avg WIP (time-weighted): " + String.format("%.2f", avgWIP()));
traceln("Flow time std dev, shipped only (h): " + String.format("%.2f", flowTimeStd()));
traceln("Total tablets shipped: " + (long) totalTabletsShipped);
traceln("Total bottles shipped: " + (long) totalBottlesShipped);
traceln("--- Per-product (shipped) ---");
String[] _pn = {"CoreTab", "PlusTab", "MaxTab"};
for (int i = 0; i < 3; i++) {
    double mft = shippedByProduct[i] > 0 ? flowTimeByProduct[i] / shippedByProduct[i] : 0;
    traceln("  " + _pn[i] + ": shipped=" + shippedByProduct[i]
        + " scrapped=" + scrappedByProduct[i]
        + " bottles=" + (long) bottlesByProduct[i]
        + " meanFlow(h)=" + String.format("%.2f", mft));
}
traceln("--- Scrap/loss breakdown ---");
traceln("  Full-batch premix failure scraps: " + premixFailureScrapCount);
traceln("  Premix yield loss tablets:        " + (long) totalPremixYieldLossTablets);
traceln("  Packaging/inspection yield loss:  " + (long) totalPackagingYieldLossTablets);
traceln("  Bottle-fill leftover tablets:     " + (long) totalLeftoverTabletsScrapped);
traceln("--- Packaging setup/changeover ---");
traceln("  Setups:      " + packageSetupCount + "  hours=" + String.format("%.2f", totalSetupHours));
traceln("  Changeovers: " + packageChangeoverCount + "  hours=" + String.format("%.2f", totalChangeoverHours));
traceln("--- On-time delivery (ship vs due = plannedRelease + " + String.format("%.0f", dueLeadTimeHours) + "h lead + 24h grace) ---");
traceln("  Late shipments (shipped after due date): " + releasePlanViolationCount + " of " + shippedDueChecked);
double _otd = shippedDueChecked > 0 ? 100.0 * (shippedDueChecked - releasePlanViolationCount) / shippedDueChecked : 100.0;
traceln("  On-time delivery (%):             " + String.format("%.1f", _otd));
traceln("  Mean tardiness, late only (h):    " + String.format("%.2f", releasePlanViolationCount > 0 ? totalTardinessHours / releasePlanViolationCount : 0.0));
traceln("  Max tardiness (h):                " + String.format("%.2f", maxTardinessHours));
double _otdTight = shippedDueChecked > 0 ? 100.0 * (shippedDueChecked - lateShipmentsTight) / shippedDueChecked : 100.0;
traceln("  [sensitivity] OTD at tighter 210h promise: " + String.format("%.1f", _otdTight) + "%  (" + lateShipmentsTight + " late)");
traceln("  [ref] Max release-into-line dev (h): " + String.format("%.2f", maxReleaseDeviationHours));
traceln("--- Queue waits by stage (h) ---");
for (int i = 0; i < qStageNames.length && i < qSum.length; i++) {
    double meanQ = qCount[i] > 0 ? qSum[i] / qCount[i] : 0;
    traceln("  " + qStageNames[i] + ": mean=" + String.format("%.2f", meanQ)
        + " max=" + String.format("%.2f", qMax[i]) + " n=" + qCount[i]);
}
traceln("--- Weekly shipments/scrap (weeks with activity) ---");
for (int w = 0; w < weeklyBatchesShipped.length; w++) {
    if (weeklyBatchesShipped[w] > 0 || weeklyBatchesScrapped[w] > 0) {
        traceln("  Week " + w + ": shipped batches=" + weeklyBatchesShipped[w]
            + " scrapped batches=" + weeklyBatchesScrapped[w]
            + " bottles=" + (long) weeklyBottlesShipped[w]
            + " tablets=" + (long) weeklyTabletsShipped[w]);
    }
}
traceln("--- Failure / scrap mechanisms ---");
traceln("  Premix hazard-scrap batches (active): " + premixFailureScrapCount);
traceln("  ResourcePool breakdowns (repair events): total=" + totalFailures + " | blenderNew=" + failureCountBlenderNew
    + " blenderOld=" + failureCountBlenderOld + " packagingLine=" + failureCountPackaging);
if (totalFailures == 0) traceln("  NOTE: 0 breakdowns recorded. If the pools have no TimeUntilFailure configured, the fitted premix/packaging REPAIR distributions are not being exercised by the model - verify before citing them in input modeling.");
traceln("--- Utilisation (mean 0..1) ---");
traceln("  blenderNew    : " + String.format("%.3f", blenderNew.utilization()));
traceln("  blenderOld    : " + String.format("%.3f", blenderOld.utilization()));
traceln("  granulator    : " + String.format("%.3f", granulator.utilization()));
traceln("  dryer         : " + String.format("%.3f", dryer.utilization()));
traceln("  press         : " + String.format("%.3f", press.utilization()));
traceln("  coater        : " + String.format("%.3f", coater.utilization()));
traceln("  packagingLine : " + String.format("%.3f", packagingLine.utilization()));
traceln("  cleaningTeam  : " + String.format("%.3f", cleaningTeam.utilization()));
traceln("=== END BASELINE RESULTS ===");
return 0;]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
