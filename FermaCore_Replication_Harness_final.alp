						</Parameter>
						<Parameter>
							<Name><![CDATA[onExit]]></Name>
							<Value Class="CodeValue">
								<Code><![CDATA[int i = Math.min(sourceIndex, productPlan.length - 1);
double dm = Math.max(1.0e-9, demandMultiplier);
agent.product = productPlan[i];
agent.plannedProduct = (originalProductPlan != null && i < originalProductPlan.length) ? originalProductPlan[i] : productPlan[i];
agent.plannedReleaseTime = arrivalTimes[i] / dm;
agent.batchKg = 150;
agent.tablets = 300000;
agent.arrivalTime = time();
agent.scrapCause = "";
agent.packLineIndex = -1;

// Due date for the one-day deviation rule. The case ties the rule to each order's
// own planned PRODUCTION date, so due = planned release + a nominal production
// lead time + the 24 h tolerance. dueLeadTimeHours defaults to the baseline mean
// flow time (~182 h at N=50): a batch is "on time" if volume has not pushed its
// completion beyond the baseline promise plus one day. This avoids the artefact of
// bucketing the front-loaded plan into one impossible weekly due date.
agent.dueTime = agent.plannedReleaseTime + dueLeadTimeHours + 24.0;

// Release-INTO-LINE timing only (kept for reference; the source releases on plan
// so this stays small by construction). This is NOT on-time delivery.
double releaseTimingDev = Math.abs(time() - agent.plannedReleaseTime);
totalReleaseDeviationHours += releaseTimingDev;
maxReleaseDeviationHours = Math.max(maxReleaseDeviationHours, releaseTimingDev);

updateWIPArea();
currentWIP++;
maxWIP = Math.max(maxWIP, currentWIP);
dsWIP.add(time(), currentWIP);
sourceIndex++;
]]></Code>
							</Value>
