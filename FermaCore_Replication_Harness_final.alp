				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[int]]></ReturnType>
					<Id>1783000000192</Id>
					<Name><![CDATA[choosePackagingLine]]></Name>
					<X>-170</X><Y>300</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[product]]></Name>
						<Type><![CDATA[String]]></Type>
					</Parameter>
					<Body><![CDATA[ensurePackagingArrays();
int n = Math.max(1, Math.min(numPackagingLines, lastProductOnPackLine.length));

// Prefer an idle line that already handled this product, to avoid a changeover.
for (int i = 0; i < n; i++) {
    if (!packLineBusy[i] && product.equals(lastProductOnPackLine[i])) {
        return i;
    }
}

// Otherwise use the first idle line.
for (int i = 0; i < n; i++) {
    if (!packLineBusy[i]) {
        return i;
    }
}

// Defensive fallback. The Seize block should exit only after a packaging resource is available.
return 0;]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[int]]></ReturnType>
					<Id>1783000000193</Id>
					<Name><![CDATA[assignPackagingLine]]></Name>
					<X>-170</X><Y>360</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[a]]></Name>
						<Type><![CDATA[BatchAgent]]></Type>
					</Parameter>
					<Body><![CDATA[ensurePackagingArrays();
int i = choosePackagingLine(a.product);
a.packLineIndex = i;
a.productChanged = lastProductOnPackLine[i].length() > 0 && !a.product.equals(lastProductOnPackLine[i]);
packLineBusy[i] = true;
return 0;]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[int]]></ReturnType>
					<Id>1783000000194</Id>
					<Name><![CDATA[releasePackagingLine]]></Name>
					<X>-170</X><Y>400</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[a]]></Name>
						<Type><![CDATA[BatchAgent]]></Type>
					</Parameter>
					<Body><![CDATA[ensurePackagingArrays();
int i = a.packLineIndex;
if (i >= 0 && i < lastProductOnPackLine.length) {
    lastProductOnPackLine[i] = a.product;
    packLineBusy[i] = false;
}
lastProductOnLine = a.product; // kept as a fallback/readout from the older single-line logic
a.packLineIndex = -1;
return 0;]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1783000000947</Id>
					<Name><![CDATA[ensurePackagingArrays]]></Name>
					<X>-170</X><Y>240</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[int n = Math.max(1, numPackagingLines);
if (lastProductOnPackLine == null || lastProductOnPackLine.length != n || packLineBusy == null || packLineBusy.length != n) {
    String[] newLast = new String[n];
    boolean[] newBusy = new boolean[n];
    for (int i = 0; i < n; i++) {
        newLast[i] = (lastProductOnPackLine != null && i < lastProductOnPackLine.length && lastProductOnPackLine[i] != null) ? lastProductOnPackLine[i] : "";
        newBusy[i] = (packLineBusy != null && i < packLineBusy.length) ? packLineBusy[i] : false;
    }
    lastProductOnPackLine = newLast;
    packLineBusy = newBusy;
}
return 0;]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1783000000948</Id>
					<Name><![CDATA[recordQueueWait]]></Name>
					<X>-170</X><Y>380</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[stage]]></Name>
						<Type><![CDATA[int]]></Type>
					</Parameter>
					<Parameter>
						<Name><![CDATA[wait]]></Name>
						<Type><![CDATA[double]]></Type>
					</Parameter>
					<Body><![CDATA[if (stage >= 0 && stage < qSum.length) {
    double w = Math.max(0.0, wait);
    qSum[stage] += w;
    qCount[stage]++;
    qMax[stage] = Math.max(qMax[stage], w);
}
return 0;]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1783000000949</Id>
					<Name><![CDATA[recordWeeklyShipment]]></Name>
					<X>-170</X><Y>280</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[a]]></Name>
						<Type><![CDATA[BatchAgent]]></Type>
					</Parameter>
					<Body><![CDATA[int week = (int) Math.floor(time() / 168.0);
if (week >= 0 && week < weeklyTabletsShipped.length) {
    weeklyTabletsShipped[week] += a.tablets;
    weeklyBottlesShipped[week] += a.bottlesShipped;
    weeklyBatchesShipped[week]++;
    a.completionWeek = week;
}
return 0;]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1783000000950</Id>
					<Name><![CDATA[recordWeeklyScrap]]></Name>
					<X>-170</X><Y>320</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[a]]></Name>
						<Type><![CDATA[BatchAgent]]></Type>
					</Parameter>
					<Body><![CDATA[int week = (int) Math.floor(time() / 168.0);
if (week >= 0 && week < weeklyBatchesScrapped.length) {
    weeklyBatchesScrapped[week]++;
}
return 0;]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1783000000951</Id>
					<Name><![CDATA[tryFinishBaseline]]></Name>
					<X>-170</X><Y>340</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[if (!baselineResultsPrinted && batchesShipped + batchesScrapped >= targetBatchCount) {
    baselineResultsPrinted = true;
    printBaselineResults();
    finishSimulation();
}
return 0;]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1783000001010</Id>
					<Name><![CDATA[updateWIPArea]]></Name>
					<X>-170</X><Y>480</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[// Accumulate the time-integral of WIP. Call this BEFORE changing currentWIP.
double now = time();
areaWIP += currentWIP * (now - lastWIPChangeTime);
lastWIPChangeTime = now;
return 0;]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1783000001011</Id>
					<Name><![CDATA[avgWIP]]></Name>
					<X>-170</X><Y>460</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[// Time-weighted mean WIP = integral(WIP dt) / T. Flush the open segment first.
updateWIPArea();
return time() > 0 ? areaWIP / time() : 0;]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1783000001012</Id>
					<Name><![CDATA[flowTimeStd]]></Name>
					<X>-170</X><Y>440</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[// Population std dev of shipped-batch flow time.
if (batchesShipped < 2) return 0;
double mean = totalFlowTime / batchesShipped;
double var = sumFlowTimeSq / batchesShipped - mean * mean;
return var > 0 ? Math.sqrt(var) : 0;]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[int]]></ReturnType>
					<Id>1783000001013</Id>
					<Name><![CDATA[productIndex]]></Name>
					<X>-170</X><Y>420</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[p]]></Name>
						<Type><![CDATA[String]]></Type>
					</Parameter>
					<Body><![CDATA[// CoreTab=0, PlusTab=1, MaxTab=2, unknown=-1
if (p == null) return -1;
if (p.equals("CoreTab")) return 0;
if (p.equals("PlusTab")) return 1;
if (p.equals("MaxTab")) return 2;
return -1;]]></Body>
				</Function>
			</Functions>
