		<!--   =========  Parameter Variation Experiment   ========  -->
		<ParamVariationExperiment ActiveObjectClassId="1782117159878">
			<Id>1783000002000</Id>
			<Name><![CDATA[ReplicationsExp]]></Name>
			<CommandLineArguments><![CDATA[]]></CommandLineArguments>
			<InitialSetupCode><![CDATA[// Replication harness — CSV filename is auto-derived from parameter values in AfterSimulationRun.
// To run a new scenario: change the relevant parameter to its new fixed value and press Run.
repCount = 0;
traceln("ReplicationsExp starting — CSV filename will be derived from parameter values.");]]></InitialSetupCode>
			<MaximumMemory>4096</MaximumMemory>
			<RandomNumberGenerationType>randomSeed</RandomNumberGenerationType>
			<CustomGeneratorCode>new Random()</CustomGeneratorCode>
			<AfterSimulationRunCode><![CDATA[// One row per replication. root = the finished Main agent.
// CSV filename is auto-derived from parameter values — no manual filename change needed.
repCount++;
try {
    // --- derive scenario name by composing all non-default parameter values ---
    java.util.List<String> parts = new java.util.ArrayList<String>();
    if (root.numDryers > 1)                        parts.add("dryer"      + root.numDryers);
    if (root.cleaningTeamCapacity > 1)             parts.add("cleanTeam"  + root.cleaningTeamCapacity);
    if (root.numPackagingLines > 3)                parts.add("packLine"   + root.numPackagingLines);
    if (root.targetBatchCount != 50)               parts.add("batches"    + root.targetBatchCount);
    if (root.groupByProduct)                       parts.add("groupByProduct");
    if (root.demandMultiplier != 1.0)              parts.add("demand"     + String.valueOf(root.demandMultiplier).replace(".", "p"));
    if (root.pressScrapRate != 0.10)               parts.add("i40_scrap"  + String.valueOf(root.pressScrapRate).replace(".", "p"));
    if (root.queueStrategy != 0)                   parts.add("queue"      + root.queueStrategy);
    String scenario = parts.isEmpty() ? "baseline" : String.join("_", parts);
    traceln("user.dir = " + System.getProperty("user.dir"));
    String csvPath = System.getProperty("user.dir") + "/data/FermaCore_" + scenario + ".csv";
new java.io.File(System.getProperty("user.dir") + "/data").mkdirs();

    // --- write header on first rep, then append data ---
    boolean firstRep = (repCount == 1);
    java.io.FileWriter fw = new java.io.FileWriter(csvPath, !firstRep);
    if (firstRep) {
        fw.write("rep,bottlesShipped,batchesShipped,batchesScrapped,scrapRate,meanFlowTime,maxFlowTime,flowTimeStd,avgWIP,maxWIP,dryerUtil,cleaningTeamUtil,packagingUtil,pressUtil,coaterUtil,coreTabBottles,plusTabBottles,maxTabBottles,lateShipments,onTimePct,maxTardiness,maxReleaseDev,completionTime\n");
        traceln("CSV created: " + csvPath);
    }
    fw.write(repCount
        + "," + root.totalBottlesShipped
        + "," + root.batchesShipped
        + "," + root.batchesScrapped
        + "," + root.scrapRate()
        + "," + root.meanFlowTime()
        + "," + root.maxFlowTime
        + "," + root.flowTimeStd()
        + "," + root.avgWIP()
        + "," + root.maxWIP
        + "," + root.dryer.utilization()
        + "," + root.cleaningTeam.utilization()
        + "," + root.packagingLine.utilization()
        + "," + root.press.utilization()
        + "," + root.coater.utilization()
        + "," + root.bottlesByProduct[0]
        + "," + root.bottlesByProduct[1]
        + "," + root.bottlesByProduct[2]
        + "," + root.releasePlanViolationCount
        + "," + (root.shippedDueChecked > 0 ? 100.0 * (root.shippedDueChecked - root.releasePlanViolationCount) / root.shippedDueChecked : 100.0)
        + "," + root.maxTardinessHours
        + "," + root.maxReleaseDeviationHours
        + "," + root.time()
        + "\n");
    fw.close();
} catch (Exception e) {
    traceln("CSV write error: " + e);
}]]></AfterSimulationRunCode>
