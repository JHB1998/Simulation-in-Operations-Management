				<EmbeddedObject>
					<Id>1783000000144</Id>
					<Name><![CDATA[sinkShipped]]></Name>
					<X>1210</X><Y>650</Y>
					<Label><X>-25</X><Y>-20</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<ActiveObjectClass>
						<PackageName><![CDATA[com.anylogic.libraries.processmodeling]]></PackageName>
						<ClassName><![CDATA[Sink]]></ClassName>
					</ActiveObjectClass>
					<GenericParameterSubstitute>
						<GenericParameterSubstituteReference>
							<PackageName><![CDATA[com.anylogic.libraries.processmodeling]]></PackageName>
							<ClassName><![CDATA[Sink]]></ClassName>
							<ItemName><![CDATA[1412336242929]]></ItemName>
						</GenericParameterSubstituteReference>
					</GenericParameterSubstitute>
					<Parameters>
						<Parameter>
							<Name><![CDATA[onEnter]]></Name>
							<Value Class="CodeValue">
								<Code><![CDATA[int bs = bottleSize(agent.product);
double tabletsBeforeBottleFill = agent.tablets;
agent.bottlesShipped = Math.floor(tabletsBeforeBottleFill / bs);
agent.tablets = agent.bottlesShipped * bs;
agent.leftoverTabletsScrapped = Math.max(0.0, tabletsBeforeBottleFill - agent.tablets);
totalLeftoverTabletsScrapped += agent.leftoverTabletsScrapped;

batchesShipped++;
agent.completionTime = time();
double ft = time() - agent.arrivalTime;
totalFlowTime += ft;
sumFlowTimeSq += ft * ft;
maxFlowTime = Math.max(maxFlowTime, ft);

// === TRUE ON-TIME DELIVERY (ship time vs due date) ===
double lateBy = agent.completionTime - agent.dueTime;   // >0 means late
if (lateBy > 0) {
    releasePlanViolationCount++;          // now: batches that SHIP after their due date
    totalTardinessHours += lateBy;
    maxTardinessHours = Math.max(maxTardinessHours, lateBy);
}
// Sensitivity: a tighter 210h promise (+24h grace) reported alongside the main KPI,
// so the OTD conclusion can be shown to be robust to the chosen promise length.
double dueTight = agent.plannedReleaseTime + 210.0 + 24.0;
if (agent.completionTime > dueTight) lateShipmentsTight++;
shippedDueChecked++;

totalTabletsShipped += agent.tablets;
totalBottlesShipped += agent.bottlesShipped;
int _pi = productIndex(agent.product);
if (_pi >= 0) { shippedByProduct[_pi]++; flowTimeByProduct[_pi] += ft; bottlesByProduct[_pi] += agent.bottlesShipped; }
recordWeeklyShipment(agent);
updateWIPArea();
currentWIP = Math.max(0, currentWIP - 1);
dsWIP.add(time(), currentWIP);
traceln("SHIPPED  | t=" + String.format("%.2f", time()) + " | product=" + agent.product
    + " | line=" + agent.packLineIndex
    + " | tablets=" + (long)agent.tablets + " | bottles=" + (long)agent.bottlesShipped
    + " | leftover=" + (long)agent.leftoverTabletsScrapped
    + " | flowTime=" + String.format("%.2f h", ft));
tryFinishBaseline();
]]></Code>
							</Value>
						</Parameter>
						<Parameter>
							<Name><![CDATA[destroyEntity]]></Name>
							<Value Class="CodeValue">
								<Code><![CDATA[true]]></Code>
							</Value>
						</Parameter>
					</Parameters>
