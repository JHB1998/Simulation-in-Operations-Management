	<Id>1782117159874</Id>
	<Name><![CDATA[FermaCore_Replication_Harness_final]]></Name>
	<EngineVersion>6</EngineVersion>
	<JavaPackageName><![CDATA[fermacore]]></JavaPackageName>
	<ModelTimeUnit><![CDATA[Hour]]></ModelTimeUnit>
	<Folders>
	</Folders>
	<ActiveObjectClasses>
		<!--   =========   Active Object Class   ========  -->
		<ActiveObjectClass>
			<Id>1782117159878</Id>
			<Name><![CDATA[Main]]></Name>
			<StartupCode><![CDATA[// === VOLUME REBUILD (added): regenerate plan arrays from targetBatchCount ===
// Preserves the baseline product mix (17 CoreTab / 18 PlusTab / 15 MaxTab => ~34/36/30%)
// and the cadence of 10 batches/day at 0.5 h gaps, a new day every 24 h.
// At targetBatchCount==50 this reproduces the original 50-batch plan.
{
    int N = targetBatchCount;
    double[] _at = new double[N];
    for (int k = 0; k < N; k++) {
        int day = k / 10;
        int slot = k % 10;
        _at[k] = day * 24.0 + slot * 0.5;
    }
    arrivalTimes = _at;
    double[] prop = { 17.0/50.0, 18.0/50.0, 15.0/50.0 };
    String[] names = { "CoreTab", "PlusTab", "MaxTab" };
    int[] cnt = new int[3];
    double[] rem = new double[3];
    int assigned = 0;
    for (int j = 0; j < 3; j++) {
        double exact = prop[j] * N;
        cnt[j] = (int) Math.floor(exact);
        rem[j] = exact - cnt[j];
        assigned += cnt[j];
    }
    int leftover = N - assigned;
    while (leftover > 0) {
        int best = 0;
        for (int j = 1; j < 3; j++) if (rem[j] > rem[best]) best = j;
        cnt[best]++; rem[best] = -1; leftover--;
    }
    java.util.List<String> seq = new java.util.ArrayList<String>();
    int[] left3 = { cnt[0], cnt[1], cnt[2] };
    int order = 0;
    while (seq.size() < N) {
        boolean placed = false;
        for (int step = 0; step < 3 && !placed; step++) {
            int j = (order + step) % 3;
            if (left3[j] > 0) {
                int run = Math.min(5, left3[j]);
                for (int r = 0; r < run && seq.size() < N; r++) { seq.add(names[j]); left3[j]--; }
                order = (j + 1) % 3;
                placed = true;
            }
        }
        if (!placed) break;
    }
    productPlan = seq.toArray(new String[0]);
}
// === END VOLUME REBUILD ===

// === VERIFICATION: DATA IMPORT CHECK ===
traceln("=== DATA CHECK ===");
originalProductPlan = productPlan.clone();
ensurePackagingArrays();
traceln("productPlan.length = " + productPlan.length + "  (expect " + targetBatchCount + ")");
traceln("arrivalTimes.length = " + arrivalTimes.length + "  (expect " + targetBatchCount + ")");
int _core=0, _plus=0, _max=0;
for (String p : productPlan) {
    if (p.equals("CoreTab")) _core++;
    else if (p.equals("PlusTab")) _plus++;
    else if (p.equals("MaxTab")) _max++;
    else traceln("UNKNOWN PRODUCT: " + p);
}
traceln("CoreTab=" + _core + "  PlusTab=" + _plus + "  MaxTab=" + _max + "  (mix preserved from 17 / 18 / 15)");
traceln("First: " + productPlan[0] + "  Last: " + productPlan[productPlan.length-1]);
traceln("Packaging line memory slots = " + lastProductOnPackLine.length);
traceln("=== END DATA CHECK ===");

// Optional scenario: resequence all 50 planned batches by product.
// Keep this OFF for the strict baseline. It is useful for a scenario, but it should be
// discussed against the ±1 day production-plan constraint in the report.
if (groupByProduct) {
    traceln("WARNING: groupByProduct=true. This is a sequencing scenario, not the strict draft-plan baseline.");
    java.util.Arrays.sort(productPlan);
}
]]></StartupCode>
