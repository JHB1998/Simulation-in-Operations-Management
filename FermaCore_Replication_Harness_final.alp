					<Name><![CDATA[sinkScrapped]]></Name>
					<X>770</X><Y>300</Y>
					<Label><X>-80</X><Y>30</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<ActiveObjectClass>
						<PackageName><![CDATA[com.anylogic.libraries.processmodeling]]></PackageName>
						<ClassName><![CDATA[Sink]]></ClassName>
					</ActiveObjectClass>
					<GenericParameterSubstitute>
						<GenericParameterSubstituteReference>
							<PackageName><![CDATA[com.anylogic.libraries.processmodeling]]></PackageName>
							<ClassName><![CDATA[Sink]]></ClassName>
							<ItemName><![CDATA[1412336242929]]></ItemName>
						</GenericParameterSubstituteReference>
					</GenericParameterSubstitute>
					<Parameters>
						<Parameter>
							<Name><![CDATA[onEnter]]></Name>
							<Value Class="CodeValue">
								<Code><![CDATA[agent.scrapped = true;
if (agent.scrapCause == null || agent.scrapCause.length() == 0) agent.scrapCause = "Unspecified scrap";
batchesScrapped++;
recordWeeklyScrap(agent);
int _pi = productIndex(agent.product);
if (_pi >= 0) scrappedByProduct[_pi]++;
updateWIPArea();
currentWIP = Math.max(0, currentWIP - 1);
dsWIP.add(time(), currentWIP);
traceln("SCRAPPED | t=" + String.format("%.2f", time()) + " | product=" + agent.product
    + " | cause=" + agent.scrapCause + " | total_scrapped=" + batchesScrapped);
tryFinishBaseline();]]></Code>
							</Value>
						</Parameter>
